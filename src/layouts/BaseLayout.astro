---
import '../styles/global.css';

interface Props {
    title?: string;
    description?: string;
}

const {
    title = 'FY Tutoring',
    description = 'Expert tutoring for OC and Selective by high school students across Sydney.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
    </head>
    <body>
        <slot />
    </body>
</html>