---
import tutors from '../data/tutors.json';
import '../styles/tutors.css';
---
<div class="tutors-container">
    <section class="tutors-section" id="tutors">
        <div class="tutors-header-wrap">

            <div class="tutors-left-header">
                <h2 class="tutors-h2">Meet Our Tutors</h2>
                <p class="tutors-sub">
                    High-achieving mentors dedicated to helping you excel in your studies.
                </p>
            </div>

            <div class="tutors-nav" aria-label="Carousel navigation">
                <button class="tutors-btn prev" id="tutors-prev" aria-label="Previous slide">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button class="tutors-btn next" id="tutors-next" aria-label="Next slide">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
            </div>
        </div>

        <div class="tutors-slider-container">
            <ul class="tutors-track" id="tutors-track">
                {tutors.map((tutor) => ( 
                    <li class="tutors-slide">
                        <div class="col-teacher">
                            <div class="tile-teacher shadow-hover" data-id={tutor.id}>
                                <div class="text">
                                    <div class="heading h2">{tutor.name}</div>
                                    <div class="qualifications">{tutor.qualifications}</div>
                                </div>
                                <div class="image">
                                    <img 
                                        src={tutor.image} 
                                        alt={`Portrait of ${tutor.name}`} 
                                        loading="lazy" 
                                        width="400" height="533"/>
                                </div>
                            </div>
                        </div>
                    </li>
                ))}
            </ul>
        </div>
    </section>
</div>

<script src="../scripts/tutors.ts"></script>
